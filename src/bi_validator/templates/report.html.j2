<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{ payload.dashboard }} Validation Report</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 24px; color: #1f2933; }
      h1, h2 { margin-bottom: 8px; }
      .summary { display: grid; grid-template-columns: repeat(2, minmax(220px, 1fr)); gap: 12px; margin-bottom: 24px; }
      .card { border: 1px solid #d9e2ec; border-radius: 8px; padding: 12px; background: #f8fbff; }
      .status { font-weight: 700; }
      .FAILED { color: #b42318; }
      .PASSED { color: #027a48; }
      ul { padding-left: 20px; }
      .findings li { margin: 4px 0; }
      .meta { color: #52606d; font-size: 0.9rem; }
      table { border-collapse: collapse; width: 100%; margin-top: 12px; }
      th, td { border: 1px solid #d9e2ec; padding: 8px; text-align: left; }
      th { background: #eef2f6; }
      .shot { margin: 6px 0; }
    </style>
  </head>
  <body>
    <h1>Dashboard Validation Report</h1>
    <div class="summary">
      <div class="card">
        <div>Dashboard</div>
        <strong>{{ payload.dashboard }}</strong>
      </div>
      <div class="card">
        <div>Status</div>
        <div class="status {{ payload.status }}">{{ payload.status }}</div>
      </div>
      <div class="card">
        <div>Platform</div>
        <strong>{{ payload.platform }}</strong>
      </div>
      <div class="card">
        <div>Navigation Nodes</div>
        <strong>{{ payload.summary.navigation_nodes }}</strong>
      </div>
    </div>

    <h2>Workflow</h2>
    <div class="card">
      <div>Source: {{ payload.workflow.source }}</div>
      <div>Keywords: {{ payload.workflow.keywords | join(", ") }}</div>
      <div>Rationale: {{ payload.workflow.rationale | join(" | ") }}</div>
    </div>

    <h2>Issues</h2>
    <table>
      <thead>
        <tr>
          <th>Category</th>
          <th>Severity</th>
          <th>Code</th>
          <th>Message</th>
          <th>Path</th>
        </tr>
      </thead>
      <tbody>
        {% for finding in payload.findings %}
        <tr>
          <td>{{ finding.category }}</td>
          <td>{{ finding.severity }}</td>
          <td>{{ finding.code }}</td>
          <td>{{ finding.message }}</td>
          <td>{{ finding.path | join(" -> ") }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>

    <h2>Navigation Tree</h2>
    <ul>
      {{ navigation_html | safe }}
    </ul>
  </body>
</html>
